{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "store:default",
    "core:menu:default",
    "core:menu:allow-new",
    "core:menu:allow-create-default",
    "core:menu:allow-append",
    "core:menu:allow-set-as-app-menu"
  ]
}
