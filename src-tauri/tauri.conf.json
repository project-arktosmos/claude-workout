{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "claude-workout",
  "version": "0.1.0",
  "identifier": "com.arktosmos.claude-workout",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1995",
    "beforeDevCommand": "pnpm dev:vite",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Workout",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
